<section class="container pb-5 mt-5">
  <div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
      <div class="card border-0 rounded-4 overflow-hidden" style="box-shadow: 0 15px 35px rgba(0,0,0,0.1);">
        <div class="card-body p-4 p-md-5">
          <div class="text-center mb-4">
            <h2 class="fw-bold mb-1 font-outfit text-dark">Welcome Back</h2>
            <p class="text-muted small">Enter your credentials to access your account.</p>
          </div>
          <form action="/auth/login" method="POST">
            <div class="mb-3">
              <label class="form-label fw-bold text-muted small text-uppercase" style="letter-spacing: 0.05em;">Email Address</label>
              <div class="input-group input-group-lg bg-light rounded-3 overflow-hidden border">
                <span class="input-group-text bg-transparent border-0 pe-1"><i class="fa-regular fa-envelope text-muted"></i></span>
                <input type="email" class="form-control bg-transparent border-0 ps-2" name="email" required placeholder="name@example.com" />
              </div>
            </div>
            <div class="mb-4">
              <div class="mb-1">
                <label class="form-label fw-bold text-muted small text-uppercase mb-0" style="letter-spacing: 0.05em;">Password</label>
              </div>
              <div class="input-group input-group-lg bg-light rounded-3 overflow-hidden border">
                <span class="input-group-text bg-transparent border-0 pe-1"><i class="fa-solid fa-lock text-muted"></i></span>
                <input type="password" class="form-control bg-transparent border-0 ps-2" name="password" required placeholder="********" />
              </div>
              <div class="text-end mt-2">
                <a href="/auth/forgot-password" class="small text-primary text-decoration-none fw-medium">Forgot Password?</a>
              </div>
            </div>
            <div class="d-grid mt-4">
              <button class="btn btn-primary btn-lg rounded-pill fw-bold shadow position-relative overflow-hidden" type="submit">
                <span class="position-relative z-1 d-flex align-items-center justify-content-center">
                  Login Securely <i class="fa-solid fa-arrow-right ms-2"></i>
                </span>
              </button>
            </div>
            <div class="text-center mt-4">
              <p class="text-muted mb-0">Don't have an account? <a href="/auth/register" class="text-primary fw-bold text-decoration-none border-bottom border-primary border-2 pb-1">Register here</a></p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>