<section class="container pb-5 mt-5">
  <div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
      <div class="card border-0 rounded-4 overflow-hidden" style="box-shadow: 0 15px 35px rgba(0,0,0,0.1);">
        <div class="card-body p-4 p-md-5">
          <div class="text-center mb-4">
            <h2 class="fw-bold mb-1 font-outfit text-dark">Forgot Password</h2>
            <p class="text-muted small">Enter your account email and we will send a reset link.</p>
          </div>
          <form action="/auth/forgot-password" method="POST">
            <div class="mb-4">
              <label class="form-label fw-bold text-muted small text-uppercase" style="letter-spacing: 0.05em;">Email Address</label>
              <div class="input-group input-group-lg bg-light rounded-3 overflow-hidden border">
                <span class="input-group-text bg-transparent border-0 pe-1"><i class="fa-regular fa-envelope text-muted"></i></span>
                <input type="email" class="form-control bg-transparent border-0 ps-2" name="email" required placeholder="name@example.com" />
              </div>
            </div>
            <div class="d-grid mt-4">
              <button class="btn btn-primary btn-lg rounded-pill fw-bold shadow" type="submit">
                Send Reset Link <i class="fa-solid fa-paper-plane ms-2"></i>
              </button>
            </div>
            <div class="text-center mt-4">
              <a href="/auth/login" class="text-primary fw-bold text-decoration-none">Back to Login</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
