<section class="container py-5 mt-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 pb-3 border-bottom">
    <div>
      <div class="badge bg-primary-subtle text-primary mb-2 px-3 py-2 shadow-sm rounded-pill fw-bold text-uppercase" style="letter-spacing: 0.05em;">
        <i class="fa-solid fa-tags me-2"></i>Promotions
      </div>
      <h2 class="display-6 fw-bold mb-1 font-outfit text-dark">Offer Management</h2>
      <p class="text-muted fs-6 mb-0">Create seasonal discounts, coupon codes, and special pricing for your venues.</p>
    </div>
  </div>

  <div class="row g-4">
    <!-- Create Offer Form -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white h-100">
        <h4 class="fw-bold mb-4 font-outfit border-bottom pb-3"><i class="fa-solid fa-plus-circle text-primary me-2"></i> Create New Offer</h4>
        <form method="POST" action="/owner/offers" class="row g-3">
          <div class="col-12">
            <label class="form-label small fw-bold text-muted text-uppercase">Target Venue</label>
            <select name="venueId" required class="form-select bg-light border-0 py-2">
              <% venues.forEach((venue) => { %>
                <option value="<%= venue._id %>"><%= venue.name %> (<%= venue.location.city %>)</option>
              <% }) %>
            </select>
          </div>
          <div class="col-12">
            <label class="form-label small fw-bold text-muted text-uppercase">Offer Title</label>
            <input type="text" name="title" placeholder="e.g. Summer Slam 2026" required class="form-control bg-light border-0 py-2" />
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-bold text-muted text-uppercase">Type</label>
            <select name="discountType" required class="form-select bg-light border-0 py-2">
              <option value="percentage">Percentage (%)</option>
              <option value="fixed">Fixed (₹)</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-bold text-muted text-uppercase">Value</label>
            <input type="number" name="discountValue" min="1" required class="form-control bg-light border-0 py-2" placeholder="10" />
          </div>
          <div class="col-12">
            <label class="form-label small fw-bold text-muted text-uppercase">Coupon Code (Optional)</label>
            <div class="input-group">
              <span class="input-group-text bg-light border-0"><i class="fa-solid fa-ticket text-muted small"></i></span>
              <input type="text" name="code" placeholder="EID2026" class="form-control bg-light border-0 py-2 text-uppercase fw-bold" />
            </div>
          </div>
          <div class="col-12">
            <label class="form-label small fw-bold text-muted text-uppercase">Applicable Days</label>
            <select name="appliesOn" required class="form-select bg-light border-0 py-2">
              <option value="everyday">Everyday</option>
              <option value="weekday">Weekday Only</option>
              <option value="saturday">Saturday Only</option>
              <option value="sunday">Sunday Only</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-bold text-muted text-uppercase">Start Date</label>
            <input type="date" name="startDate" required class="form-control bg-light border-0 py-2" />
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-bold text-muted text-uppercase">End Date</label>
            <input type="date" name="endDate" required class="form-control bg-light border-0 py-2" />
          </div>
          <div class="col-12 mt-4">
            <button class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow-sm py-3" type="submit">
              <i class="fa-solid fa-rocket me-2"></i> Launch Offer
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Active Offers Table -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="p-4 bg-light border-bottom d-flex justify-content-between align-items-center">
          <h5 class="fw-bold mb-0 font-outfit">Active & Scheduled Offers</h5>
          <span class="badge bg-primary rounded-pill px-3 py-2 fw-bold text-uppercase small" style="letter-spacing: 0.05em;"><%= offers.length %> Total</span>
        </div>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
              <tr>
                <th class="ps-4 py-3 text-muted small fw-bold">Deal Info</th>
                <th class="py-3 text-muted small fw-bold">Target Venue</th>
                <th class="py-3 text-muted small fw-bold">Savings</th>
                <th class="py-3 text-muted small fw-bold">Validity</th>
                <th class="py-3 text-center text-muted small fw-bold">Status</th>
                <th class="pe-4 py-3 text-center text-muted small fw-bold">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (!offers || offers.length === 0) { %>
                <tr>
                  <td colspan="6" class="text-center py-5">
                    <i class="fa-solid fa-tag text-muted opacity-25 mb-3" style="font-size: 3rem;"></i>
                    <h6 class="fw-bold text-dark">No offers created yet</h6>
                    <p class="text-muted small">Boost your bookings by creating your first promotional offer.</p>
                  </td>
                </tr>
              <% } %>
              <% offers.forEach((offer) => { %>
                <tr class="transition-fast">
                  <td class="ps-4 py-4">
                    <div class="fw-bold text-dark font-outfit mb-1"><%= offer.title %></div>
                    <div class="badge bg-light text-primary border rounded-pill px-2 py-1 small fw-bold font-monospace">
                      <i class="fa-solid fa-hashtag me-1 small"></i><%= offer.code || 'NO-CODE' %>
                    </div>
                  </td>
                  <td class="py-4 text-muted small">
                    <i class="fa-solid fa-hotel me-1 opacity-50"></i> <%= offer.venue ? offer.venue.name : 'All Venues' %>
                  </td>
                  <td class="py-4">
                    <span class="fw-bold text-success">
                      <%= offer.discountType === 'percentage' ? `${offer.discountValue}% OFF` : `₹${offer.discountValue} OFF` %>
                    </span>
                  </td>
                  <td class="py-4">
                    <div class="text-dark small fw-bold"><%= formatDate(offer.startDate) %></div>
                    <div class="text-muted small">to <%= formatDate(offer.endDate) %></div>
                  </td>
                  <td class="py-4 text-center">
                    <span class="badge rounded-pill px-3 py-2 fw-bold text-uppercase shadow-sm <%= offer.isActive ? 'bg-success text-white' : 'bg-light text-muted border' %>" style="letter-spacing: 0.05em; font-size: 0.65rem;">
                       <%= offer.isActive ? 'Active' : 'Inactive' %>
                    </span>
                  </td>
                  <td class="pe-4 py-4 text-center">
                    <div class="d-flex gap-2 justify-content-center">
                      <form method="POST" action="/owner/offers/<%= offer._id %>/toggle">
                        <button class="btn btn-sm <%= offer.isActive ? 'btn-outline-warning' : 'btn-outline-success' %> rounded-pill px-3 fw-bold small-btn" type="submit">
                          <i class="fa-solid <%= offer.isActive ? 'fa-pause' : 'fa-play' %> me-1"></i> <%= offer.isActive ? 'Pause' : 'Start' %>
                        </button>
                      </form>
                      <form method="POST" action="/owner/offers/<%= offer._id %>/delete">
                        <button class="btn btn-sm btn-outline-danger rounded-circle p-2 shadow-sm delete-btn" type="submit" title="Delete Offer" onclick="return confirm('Permanently remove this offer?')">
                          <i class="fa-solid fa-trash-can"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .small-btn { font-size: 0.75rem; }
  .delete-btn { width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; }
  .table tr:hover { background-color: rgba(var(--primary-rgb), 0.02); }
</style>
