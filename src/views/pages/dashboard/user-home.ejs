<section class="container py-5 mt-4">
  <div class="card bg-primary text-white border-0 rounded-4 overflow-hidden shadow-lg mb-5 position-relative">
    <div class="position-absolute end-0 top-0 opacity-10" style="transform: translate(10%, -20%); pointer-events: none;">
      <i class="fa-solid fa-user-astronaut" style="font-size: 14rem;"></i>
    </div>
    <div class="card-body p-4 p-md-5 position-relative z-1 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
      <div>
        <div class="badge bg-white text-primary mb-3 px-3 py-2 shadow-sm rounded-pill fw-bold text-uppercase" style="letter-spacing: 0.05em;"><i class="fa-solid fa-table-tennis-paddle-ball me-2"></i> Player Dashboard</div>
        <h2 class="display-6 fw-bold mb-1 font-outfit text-white">Welcome, <%= currentUser.fullName %>!</h2>
        <p class="text-white-50 fs-5 mb-0">Manage your upcoming games and bookings.</p>
      </div>
      <div class="mt-4 mt-md-0">
        <a class="btn btn-light btn-lg rounded-pill fw-bold shadow-sm px-4" href="/venues">
          <i class="fa-solid fa-magnifying-glass me-2 text-primary"></i>Find Venues
        </a>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
    <h3 class="fw-bold mb-0 font-outfit text-dark"><i class="fa-solid fa-clock-rotate-left text-primary me-2"></i>Your Recent Bookings</h3>
    <a class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-bold shadow-sm" href="/dashboard/bookings">View All <i class="fa-solid fa-angle-right ms-1"></i></a>
  </div>

  <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th class="ps-4 py-3 text-muted text-uppercase small fw-bold" style="letter-spacing: 0.05em;">Venue Details</th>
            <th class="py-3 text-muted text-uppercase small fw-bold" style="letter-spacing: 0.05em;">Game Date</th>
            <th class="py-3 text-muted text-uppercase small fw-bold" style="letter-spacing: 0.05em;">Status</th>
            <th class="pe-4 py-3 text-muted text-uppercase small fw-bold" style="letter-spacing: 0.05em;">Advance Paid</th>
          </tr>
        </thead>
        <tbody>
          <% if (!bookings || bookings.length === 0) { %>
            <tr>
              <td colspan="4" class="text-center py-5">
                <i class="fa-regular fa-folder-open text-muted opacity-50 mb-3" style="font-size: 3rem;"></i>
                <h5 class="fw-bold text-dark">No recent bookings</h5>
                <p class="text-muted mb-0">You haven't booked any venues yet. <a href="/venues" class="text-primary fw-bold text-decoration-none border-bottom pb-1">Book now!</a></p>
              </td>
            </tr>
          <% } %>
          <% bookings.forEach((booking) => { %>
            <tr class="transition-fast hover-bg">
              <td class="ps-4 py-4">
                <a href="/dashboard/bookings/<%= booking._id %>" class="fw-bold text-dark text-decoration-none d-flex align-items-center">
                  <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                    <i class="fa-solid fa-map-location-dot"></i>
                  </div>
                  <%= booking.venue.name %>
                </a>
              </td>
              <td class="py-4 text-muted fw-medium"><i class="fa-solid fa-calendar-day text-secondary me-2"></i><%= formatDate(booking.bookingDate) %></td>
              <td class="py-4">
                <span class="badge rounded-pill px-3 py-2 fw-bold text-uppercase <%= booking.bookingStatus === 'Confirmed' ? 'bg-success-bg text-success' : (booking.bookingStatus === 'Pending' ? 'bg-warning-bg text-warning' : (booking.bookingStatus === 'Payment Due' ? 'bg-danger-subtle text-danger border border-danger border-opacity-25' : 'bg-light text-muted border')) %>" style="letter-spacing: 0.05em;">
                  <%= booking.bookingStatus %>
                </span>
              </td>
              <td class="pe-4 py-4 fw-bold text-dark fs-5">₹<%= booking.pricingBreakdown.bookingAmount %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .hover-bg:hover {
    background-color: var(--bg-surface-hover) !important;
  }
</style>