<section class="container py-5 mt-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 pb-3 border-bottom">
    <div>
      <div class="badge bg-primary-subtle text-primary mb-2 px-3 py-2 shadow-sm rounded-pill fw-bold text-uppercase" style="letter-spacing: 0.05em;">
        <i class="fa-solid fa-receipt me-2"></i>Booking Details
      </div>
      <h2 class="display-6 fw-bold mb-1 font-outfit text-dark">Ticket #<%= booking.bookingCode %></h2>
      <p class="text-muted fs-6 mb-0">Review your reservation info and payment status.</p>
    </div>
    <div class="mt-4 mt-md-0 d-flex gap-2">
      <a class="btn btn-outline-secondary rounded-pill fw-bold px-4" href="/dashboard/bookings">
        <i class="fa-solid fa-arrow-left me-2"></i>Back to List
      </a>
      <% if (booking.bookingStatus !== 'Cancelled') { %>
        <button class="btn btn-outline-danger rounded-pill fw-bold px-4" data-bs-toggle="modal" data-bs-target="#cancelModal">
          <i class="fa-solid fa-trash-can me-2"></i>Cancel
        </button>
      <% } %>
    </div>
  </div>

  <div class="row g-4">
    <!-- Left Column: Primary Details -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 mb-4 bg-white">
        <h4 class="fw-bold mb-4 font-outfit border-bottom pb-3"><i class="fa-solid fa-circle-info text-primary me-2"></i> Reservation Overview</h4>
        
        <div class="row g-4 mb-4">
          <div class="col-md-6">
            <div class="p-3 bg-light rounded-4 border">
              <span class="text-muted small fw-bold text-uppercase d-block mb-1" style="letter-spacing: 0.05em;">Venue</span>
              <div class="fw-bold text-dark fs-5"><i class="fa-solid fa-map-location-dot text-primary me-2"></i><%= booking.venue.name %></div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="p-3 bg-light rounded-4 border">
              <span class="text-muted small fw-bold text-uppercase d-block mb-1" style="letter-spacing: 0.05em;">Slot Timing</span>
              <div class="fw-bold text-dark fs-5"><i class="fa-regular fa-clock text-primary me-2"></i><%= booking.slotStartTime %> - <%= booking.slotEndTime %></div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="p-3 bg-light rounded-4 border">
              <span class="text-muted small fw-bold text-uppercase d-block mb-1" style="letter-spacing: 0.05em;">Booking Date</span>
              <div class="fw-bold text-dark fs-5"><i class="fa-regular fa-calendar-check text-primary me-2"></i><%= formatDate(booking.bookingDate) %></div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="p-3 bg-light rounded-4 border">
              <span class="text-muted small fw-bold text-uppercase d-block mb-1" style="letter-spacing: 0.05em;">Current Status</span>
              <div>
                <span class="badge rounded-pill px-3 py-2 fw-bold text-uppercase <%= booking.bookingStatus === 'Confirmed' ? 'bg-success-bg text-success' : (booking.bookingStatus === 'Pending' ? 'bg-warning-bg text-warning' : (booking.bookingStatus === 'Payment Due' ? 'bg-danger-subtle text-danger border border-danger border-opacity-25' : 'bg-light text-muted border')) %>" style="letter-spacing: 0.05em;">
                  <%= booking.bookingStatus %>
                </span>
              </div>
            </div>
          </div>
        </div>

        <% if (booking.paymentProof && booking.paymentProof.screenshot) { %>
          <div class="mt-5 pt-4 border-top">
            <h4 class="fw-bold mb-4 font-outfit"><i class="fa-solid fa-camera text-primary me-2"></i> Payment Proof</h4>
            <div class="row align-items-center">
              <div class="col-md-4 mb-3 mb-md-0">
                <div class="rounded-4 overflow-hidden border shadow-sm">
                  <a href="<%= booking.paymentProof.screenshot %>" target="_blank">
                    <img src="<%= booking.paymentProof.screenshot %>" alt="Payment proof" class="img-fluid" />
                  </a>
                </div>
              </div>
              <div class="col-md-8">
                <div class="card bg-primary-subtle border-0 rounded-4 p-4">
                  <div class="d-flex align-items-center mb-2">
                    <div class="bg-white rounded-circle p-2 me-3 text-primary"><i class="fa-solid fa-shield-check"></i></div>
                    <div class="fw-bold text-primary fs-5">Verification Status</div>
                  </div>
                  <p class="mb-0 text-muted fw-medium">
                    <%= booking.paymentProof.verifiedAt ? `Verified on ${formatDate(booking.paymentProof.verifiedAt)}` : 'Waiting for owner approval. This usually takes 1-2 hours.' %>
                  </p>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <% if (booking.disputeHistory && booking.disputeHistory.length) { %>
          <div class="mt-5 pt-4 border-top">
            <h4 class="fw-bold mb-4 font-outfit"><i class="fa-solid fa-timeline text-primary me-2"></i> Payment Review Timeline</h4>
            <div class="timeline-v2">
              <% booking.disputeHistory.forEach((item, index) => { %>
                <div class="timeline-item pb-4 position-relative ps-4 <%= index === booking.disputeHistory.length - 1 ? '' : 'border-start ms-2' %>" style="border-color: #e2e8f0 !important;">
                  <div class="position-absolute start-0 top-0 translate-middle-x bg-white border border-primary rounded-circle" style="width: 12px; height: 12px; margin-left: -5px;"></div>
                  <div class="card border-0 bg-light rounded-4 p-3 ps-4 shadow-none">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                       <span class="fw-bold text-dark"><%= item.actor %></span>
                       <span class="badge bg-white text-muted small border"><%= item.action %></span>
                    </div>
                    <p class="mb-0 text-muted small"><%= item.note %></p>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Right Column: Pricing & Re-upload -->
    <div class="col-lg-4">
      <div class="position-sticky" style="top: 100px;">
        <div class="card border-0 shadow-lg rounded-4 p-4 mb-4 bg-white">
          <h4 class="fw-bold mb-4 font-outfit border-bottom pb-3"><i class="fa-solid fa-wallet text-primary me-2"></i> Billing Summary</h4>
          
          <div class="d-flex justify-content-between mb-3 text-muted">
            <span>Payment Method</span>
            <span class="fw-bold text-dark"><%= booking.paymentMethod %></span>
          </div>
          <div class="d-flex justify-content-between mb-3 text-muted">
             <span>Reference ID</span>
             <span class="fw-bold text-dark font-monospace small"><%= booking.paymentReference || 'N/A' %></span>
          </div>
          
          <hr />
          
          <div class="d-flex justify-content-between mb-3">
             <span class="text-muted fw-bold small text-uppercase" style="letter-spacing: 0.05em;">Advance Paid</span>
             <span class="fw-bold text-primary fs-4">₹<%= booking.pricingBreakdown.bookingAmount %></span>
          </div>
          <div class="d-flex justify-content-between mb-3">
             <span class="text-muted fw-bold small text-uppercase" style="letter-spacing: 0.05em;">Due at Venue</span>
             <span class="fw-bold text-danger fs-4 bg-danger-bg px-2 py-1 rounded">₹<%= booking.pricingBreakdown.remainingAmount %></span>
          </div>
          
          <div class="bg-light p-3 rounded-4 mt-3">
             <div class="d-flex justify-content-between align-items-center">
                <span class="fw-bold text-dark">Total Price</span>
                <span class="fw-bold text-dark fs-3 font-outfit">₹<%= booking.pricingBreakdown.totalPrice %></span>
             </div>
          </div>
        </div>

        <% if (booking.bookingStatus === 'Cancelled' && booking.cancellation && booking.cancellation.reason && booking.cancellation.reason.startsWith('Payment proof rejected:')) { %>
          <div class="card border-danger border-opacity-25 shadow-sm rounded-4 p-4 bg-danger-bg">
            <h5 class="fw-bold text-danger mb-3 font-outfit"><i class="fa-solid fa-triangle-exclamation me-2"></i> Re-upload Proof</h5>
            <p class="small text-danger opacity-75 mb-4">Your previous payment screenshot was rejected. Submit a new reference to keep your booking active.</p>
            
            <form method="POST" action="/dashboard/bookings/<%= booking._id %>/reupload-payment" enctype="multipart/form-data">
              <div class="mb-3">
                <label class="form-label small fw-bold text-muted text-uppercase">New UPI Reference</label>
                <input type="text" name="paymentReference" required class="form-control border-0 shadow-sm" placeholder="e.g. 1234567890" />
              </div>
              <div class="mb-3">
                <label class="form-label small fw-bold text-muted text-uppercase">New Screenshot</label>
                <input type="file" name="paymentScreenshot" accept="image/*" required class="form-control border-0 shadow-sm" />
              </div>
              <div class="mb-4">
                <label class="form-label small fw-bold text-muted text-uppercase">Note (Optional)</label>
                <input type="text" name="resubmitNote" placeholder="Explain the discrepancy..." class="form-control border-0 shadow-sm" />
              </div>
              <button class="btn btn-danger w-100 rounded-pill fw-bold" type="submit">Resubmit for Approval</button>
            </form>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<!-- Cancel Modal -->
<div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 shadow-lg">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold font-outfit">Cancel Reservation?</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form method="POST" action="/dashboard/bookings/<%= booking._id %>/cancel">
        <div class="modal-body py-4">
          <p class="text-muted">Are you sure you want to cancel this booking? This action cannot be undone. Please provide a reason below.</p>
          <div class="bg-light p-3 rounded-4 mb-3 border">
             <label class="form-label small fw-bold text-muted text-uppercase mb-1">Cancellation Reason</label>
             <textarea name="reason" rows="3" class="form-control bg-white border-0 shadow-sm" placeholder="e.g. Change of plans / Incorrect slot selected" required></textarea>
          </div>
          <div class="alert alert-warning rounded-4 border-0 d-flex align-items-start small mb-0">
             <i class="fa-solid fa-circle-info mt-1 me-2"></i>
             <span>Cancellation policies apply. Refund of advance payment is subject to venue owner's approval.</span>
          </div>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-light rounded-pill fw-bold px-4" data-bs-dismiss="modal">Keep Booking</button>
          <button type="submit" class="btn btn-danger rounded-pill fw-bold px-4 shadow">Confirm Cancellation</button>
        </div>
      </form>
    </div>
  </div>
</div>