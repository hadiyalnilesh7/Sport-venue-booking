<section class="container py-5 mt-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-3 border-bottom">
    <div>
      <div class="badge bg-primary-subtle text-primary mb-2 px-3 py-2 shadow-sm rounded-pill fw-bold text-uppercase" style="letter-spacing: 0.05em;">
        <i class="fa-solid fa-list-ul me-2"></i>My Activity
      </div>
      <h2 class="display-6 fw-bold mb-1 font-outfit text-dark">Booking History</h2>
      <p class="text-muted fs-6 mb-0">Track all your past and upcoming sports sessions.</p>
    </div>
    <div class="mt-4 mt-md-0">
      <a class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm px-4" href="/venues">
        <i class="fa-solid fa-plus me-2"></i>New Booking
      </a>
    </div>
  </div>

  <form method="GET" action="/dashboard/bookings" class="card border-0 shadow-sm rounded-4 p-4 mb-4 bg-white">
    <div class="row g-3 align-items-end">
      <div class="col-12 col-md-auto">
        <p class="text-muted small text-uppercase fw-bold mb-0" style="letter-spacing: 0.05em;"><i class="fa-solid fa-filter text-primary me-1"></i>Filter by Date</p>
      </div>
      <div class="col-12 col-sm-5 col-md-3">
        <label class="form-label small fw-semibold text-muted mb-1">From</label>
        <input type="date" name="from" class="form-control rounded-3 border-0 bg-light" value="<%= from %>">
      </div>
      <div class="col-12 col-sm-5 col-md-3">
        <label class="form-label small fw-semibold text-muted mb-1">To</label>
        <input type="date" name="to" class="form-control rounded-3 border-0 bg-light" value="<%= to %>">
      </div>
      <div class="col-12 col-sm-2 col-md-auto d-flex gap-2">
        <button type="submit" class="btn btn-primary rounded-pill fw-bold px-4 shadow-sm"><i class="fa-solid fa-magnifying-glass me-1"></i>Search</button>
        <% if (from || to) { %>
          <a href="/dashboard/bookings" class="btn btn-outline-secondary rounded-pill fw-bold px-3"><i class="fa-solid fa-xmark"></i></a>
        <% } %>
      </div>
    </div>
  </form>

  <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th class="ps-4 py-3 text-muted text-uppercase small fw-bold" style="letter-spacing: 0.05em;">Booking ID</th>
            <th class="py-3 text-muted text-uppercase small fw-bold" style="letter-spacing: 0.05em;">Venue</th>
            <th class="py-3 text-muted text-uppercase small fw-bold" style="letter-spacing: 0.05em;">Game Date</th>
            <th class="py-3 text-muted text-uppercase small fw-bold" style="letter-spacing: 0.05em;">Status</th>
            <th class="pe-4 py-3 text-muted text-uppercase small fw-bold" style="letter-spacing: 0.05em;">Total Price</th>
          </tr>
        </thead>
        <tbody>
          <% if (!bookings || bookings.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center py-5">
                <div class="py-4">
                  <i class="fa-regular fa-calendar-xmark text-muted opacity-50 mb-3" style="font-size: 3.5rem;"></i>
                  <h5 class="fw-bold text-dark font-outfit">No bookings found</h5>
                  <p class="text-muted mb-4">You haven't made any bookings yet.</p>
                  <a href="/venues" class="btn btn-outline-primary rounded-pill fw-bold shadow-sm px-4">Browse Venues</a>
                </div>
              </td>
            </tr>
          <% } %>
          <% bookings.forEach((booking) => { %>
            <tr class="transition-fast hover-bg">
              <td class="ps-4 py-4">
                <a href="/dashboard/bookings/<%= booking._id %>" class="fw-bold text-primary text-decoration-none font-outfit">
                  <i class="fa-solid fa-hashtag text-muted me-1 small"></i><%= booking.bookingCode %>
                </a>
              </td>
              <td class="py-4">
                <div class="d-flex align-items-center">
                  <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 36px; height: 36px;">
                    <i class="fa-solid fa-map-location-dot small"></i>
                  </div>
                  <span class="fw-bold text-dark"><%= booking.venue.name %></span>
                </div>
              </td>
              <td class="py-4 text-muted fw-medium">
                <i class="fa-regular fa-calendar-day text-secondary me-2"></i><%= formatDate(booking.bookingDate) %>
              </td>
              <td class="py-4">
                <span class="badge rounded-pill px-3 py-2 fw-bold text-uppercase <%= booking.bookingStatus === 'Confirmed' ? 'bg-success-bg text-success' : (booking.bookingStatus === 'Pending' ? 'bg-warning-bg text-warning' : (booking.bookingStatus === 'Payment Due' ? 'bg-danger-subtle text-danger border border-danger border-opacity-25' : 'bg-light text-muted border')) %>" style="letter-spacing: 0.05em; font-size: 0.75rem;">
                  <%= booking.bookingStatus %>
                </span>
              </td>
              <td class="pe-4 py-4 fw-bold text-dark fs-5">
                ₹<%= booking.pricingBreakdown.totalPrice %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .hover-bg:hover {
    background-color: var(--bg-surface-hover) !important;
  }
</style>