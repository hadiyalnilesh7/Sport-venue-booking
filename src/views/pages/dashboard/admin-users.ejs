<section class="container py-5">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-4 pb-3 border-bottom">
    <div>
      <h6 class="text-uppercase text-primary fw-bold tracking-wide mb-1"><i class="fa-solid fa-users me-2"></i>Admin Dashboard</h6>
      <h2 class="fw-bold mb-0">Users & Owners</h2>
    </div>
    <div class="mt-3 mt-md-0">
      <% const pendingOwners = users.filter(u => u.role === 'owner' && !u.isApproved).length; %>
      <span class="badge bg-warning text-dark px-3 py-2 rounded-pill fs-6 border border-warning shadow-sm">
        <i class="fa-solid fa-circle-exclamation me-1"></i> <%= pendingOwners %> Owner(s) pending approval
      </span>
    </div>
  </div>

  <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-4 py-3 text-secondary fw-semibold">Name</th>
            <th class="py-3 text-secondary fw-semibold">Email</th>
            <th class="py-3 text-secondary fw-semibold">Phone</th>
            <th class="py-3 text-secondary fw-semibold">Role</th>
            <th class="py-3 text-secondary fw-semibold text-center">Status</th>
            <th class="pe-4 py-3 text-secondary fw-semibold text-center">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (!users || users.length === 0) { %>
            <tr>
              <td colspan="6" class="text-center py-5 text-muted fst-italic">No users found.</td>
            </tr>
          <% } %>
          <% users.forEach((user) => { %>
            <tr>
              <td class="ps-4 py-3 fw-bold text-dark"><i class="fa-regular fa-user me-2 text-muted"></i><%= user.fullName %></td>
              <td class="py-3 text-secondary"><i class="fa-regular fa-envelope me-1"></i><%= user.email %></td>
              <td class="py-3 text-secondary font-monospace"><i class="fa-solid fa-mobile-screen me-1"></i><%= user.phone %></td>
              <td class="py-3">
                <span class="badge <%= user.role === 'admin' ? 'bg-danger' : (user.role === 'owner' ? 'bg-primary' : 'bg-secondary') %> text-uppercase rounded-pill px-2">
                  <%= user.role %>
                </span>
              </td>
              <td class="py-3 text-center">
                <% if (user.isApproved) { %>
                  <span class="badge bg-success-bg text-success border border-success border-opacity-25 rounded-pill px-3 py-1"><i class="fa-solid fa-circle-check me-1"></i>Approved</span>
                <% } else { %>
                  <span class="badge bg-warning-bg text-warning border border-warning border-opacity-25 rounded-pill px-3 py-1"><i class="fa-solid fa-clock-rotate-left me-1"></i>Pending</span>
                <% } %>
              </td>
              <td class="pe-4 py-3 text-center">
                <% if (user.role === 'owner') { %>
                  <% if (!user.isApproved) { %>
                    <form method="POST" action="/admin/users/<%= user._id %>/approve" style="display:inline">
                      <button class="btn btn-sm btn-success rounded-pill fw-bold shadow-sm px-3" type="submit"><i class="fa-solid fa-check me-1"></i>Approve</button>
                    </form>
                  <% } else { %>
                    <form method="POST" action="/admin/users/<%= user._id %>/reject" style="display:inline">
                      <button class="btn btn-sm btn-outline-danger rounded-pill fw-bold px-3" type="submit"><i class="fa-solid fa-xmark me-1"></i>Revoke</button>
                    </form>
                  <% } %>
                <% } else { %>
                  <span class="text-muted opacity-50"><i class="fa-solid fa-minus"></i></span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>