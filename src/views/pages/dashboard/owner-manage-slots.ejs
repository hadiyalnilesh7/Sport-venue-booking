<section class="container py-5 mt-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 pb-3 border-bottom">
    <div>
      <div class="badge bg-primary-subtle text-primary mb-2 px-3 py-2 shadow-sm rounded-pill fw-bold text-uppercase" style="letter-spacing: 0.05em;">
        <i class="fa-solid fa-calendar-week me-2"></i>Availability Control
      </div>
      <h2 class="display-6 fw-bold mb-1 font-outfit text-dark"><%= venue.name %></h2>
      <p class="text-muted fs-6 mb-0">Select a date to manually block slots for maintenance or private events.</p>
    </div>
    <div class="mt-4 mt-md-0">
      <form method="GET" action="/owner/venues/<%= venue._id %>/slots" class="d-flex gap-2">
        <input type="date" name="date" value="<%= selectedDate %>" required class="form-control rounded-pill border-0 shadow-sm px-4" />
        <button class="btn btn-primary rounded-pill fw-bold px-4 shadow-sm" type="submit">Load Date</button>
      </form>
    </div>
  </div>

  <!-- Slot Visualization Grid -->
  <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 mb-5 bg-white">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
      <h4 class="fw-bold mb-0 font-outfit"><i class="fa-solid fa-layer-group text-primary me-2"></i> Slot Grid: <%= formatDate(selectedDate) %></h4>
      <div class="d-flex gap-3 small fw-bold text-muted text-uppercase" style="letter-spacing: 0.05em;">
        <span class="d-flex align-items-center"><div class="bg-success rounded-circle me-2" style="width: 10px; height: 10px;"></div> Available</span>
        <span class="d-flex align-items-center"><div class="bg-primary rounded-circle me-2" style="width: 10px; height: 10px;"></div> Booked</span>
        <span class="d-flex align-items-center"><div class="bg-danger rounded-circle me-2" style="width: 10px; height: 10px;"></div> Blocked</span>
      </div>
    </div>
    
    <div class="row g-3">
      <% slotStatusList.forEach((slot, index) => { %>
        <div class="col-6 col-md-4 col-lg-3 col-xl-2">
          <button
            type="button"
            class="slot-btn w-100 p-3 rounded-4 border-0 transition-fast position-relative <%= slot.status === 'available' ? 'bg-success-bg text-success' : (slot.status === 'booked' ? 'bg-primary-subtle text-primary' : 'bg-danger-bg text-danger') %>"
            data-start="<%= slot.startTime %>"
            data-end="<%= slot.endTime %>"
            <%= slot.status === 'available' ? '' : 'disabled' %>
            id="slot-<%= index %>"
          >
            <div class="fw-bold fs-6 font-outfit mb-1"><%= slot.startTime %></div>
            <div class="small fw-medium opacity-75"><%= slot.status.charAt(0).toUpperCase() + slot.status.slice(1) %></div>
            <% if (slot.status === 'available') { %><i class="fa-solid fa-plus position-absolute top-0 end-0 m-2 opacity-50 small"></i><% } %>
          </button>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="row g-4">
    <!-- Block Slot Form -->
    <div class="col-lg-5">
      <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white h-100">
        <h4 class="fw-bold mb-4 font-outfit border-bottom pb-3"><i class="fa-solid fa-lock text-danger me-2"></i> Block Availability</h4>
        <form method="POST" action="/owner/venues/<%= venue._id %>/slots/block" class="row g-3">
          <input type="hidden" name="date" value="<%= selectedDate %>" />
          <div class="col-12">
            <label class="form-label small fw-bold text-muted text-uppercase">Select Start Time</label>
            <select name="startTime" id="startTimeSelect" required class="form-select bg-light border-0 py-2">
              <% dailySlots.forEach((slot) => { %>
                <option value="<%= slot.startTime %>" data-end="<%= slot.endTime %>"><%= slot.startTime %> - <%= slot.endTime %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-12">
            <label class="form-label small fw-bold text-muted text-uppercase">Auto-Calculated End Time</label>
            <input type="text" name="endTime" id="endTimeInput" readonly required class="form-control bg-light border-0 py-2 fw-bold text-primary" />
          </div>
          <div class="col-12">
            <label class="form-label small fw-bold text-muted text-uppercase">Block Reason</label>
            <input type="text" name="reason" placeholder="Maintenance / Closed" class="form-control bg-light border-0 py-2" />
          </div>
          <div class="col-12">
            <label class="form-label small fw-bold text-muted text-uppercase">Auto Unblock Time (Optional)</label>
            <input type="datetime-local" name="autoUnblockAt" class="form-control bg-light border-0 py-2" />
          </div>
          <div class="col-12 mt-4 text-center">
            <button class="btn btn-danger btn-lg w-100 rounded-pill fw-bold shadow" type="submit">
              <i class="fa-solid fa-ban me-2"></i> Block Selection
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Details Column -->
    <div class="col-lg-7">
      <!-- Blocked Slots List -->
      <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 bg-white">
        <h5 class="fw-bold mb-4 font-outfit d-flex justify-content-between align-items-center">
          <span><i class="fa-solid fa-shield-halved text-danger me-2"></i> Blocked on <%= selectedDate %></span>
          <span class="badge bg-danger-bg text-danger rounded-pill fw-bold small"><%= blockedSlots.length %> Sessions</span>
        </h5>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead class="bg-light">
              <tr>
                <th class="ps-3 py-2 text-muted small fw-bold">Time Range</th>
                <th class="py-2 text-muted small fw-bold">Reason</th>
                <th class="pe-3 py-2 text-center text-muted small fw-bold">Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (!blockedSlots.length) { %>
                <tr><td colspan="3" class="text-center py-4 text-muted small">No slots blocked for this date.</td></tr>
              <% } %>
              <% blockedSlots.forEach((slot) => { %>
                <tr>
                  <td class="ps-3 py-3 fw-bold text-dark"><%= slot.startTime %> - <%= slot.endTime %></td>
                  <td class="py-3 text-muted small"><%= slot.reason || 'Manual Block' %></td>
                  <td class="pe-3 py-3 text-center">
                    <form method="POST" action="/owner/venues/<%= venue._id %>/slots/unblock">
                      <input type="hidden" name="date" value="<%= selectedDate %>" />
                      <input type="hidden" name="startTime" value="<%= slot.startTime %>" />
                      <button class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-bold border-0" type="submit">Unblock</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Booked Slots List -->
      <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        <h5 class="fw-bold mb-4 font-outfit d-flex justify-content-between align-items-center">
          <span><i class="fa-solid fa-ticket text-primary me-2"></i> Paid Bookings</span>
          <span class="badge bg-primary-subtle text-primary rounded-pill fw-bold small"><%= bookedSlots.length %> Confirmed</span>
        </h5>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0 text-muted small">
            <thead class="bg-light">
              <tr>
                <th class="ps-3 py-2 fw-bold text-uppercase">Timing</th>
                <th class="pe-3 py-2 fw-bold text-uppercase">Reference</th>
              </tr>
            </thead>
            <tbody>
              <% if (!bookedSlots.length) { %>
                <tr><td colspan="2" class="text-center py-4">Zero paid bookings for this date.</td></tr>
              <% } %>
              <% bookedSlots.forEach((slot) => { %>
                <tr>
                  <td class="ps-3 py-3 fw-bold text-dark"><%= slot.slotStartTime %> - <%= slot.slotEndTime %></td>
                  <td class="pe-3 py-3 font-monospace text-primary fw-bold"><%= slot.bookingCode %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const startSelect = document.getElementById('startTimeSelect');
    const endInput = document.getElementById('endTimeInput');
    const slotBtns = document.querySelectorAll('.slot-btn');

    const syncEndTime = () => {
      const selected = startSelect.options[startSelect.selectedIndex];
      endInput.value = selected ? selected.dataset.end : '';
    };

    if (startSelect) {
        startSelect.addEventListener('change', syncEndTime);
        syncEndTime();
    }

    slotBtns.forEach((btn) => {
      if (!btn.disabled) {
          btn.addEventListener('click', () => {
            const start = btn.dataset.start;
            for (const option of startSelect.options) {
              if (option.value === start) {
                startSelect.value = start;
                syncEndTime();
                break;
              }
            }
            slotBtns.forEach((item) => {
                item.classList.remove('bg-success');
                item.classList.remove('text-white');
                if (item.classList.contains('bg-success-bg')) {
                    item.classList.add('text-success');
                }
            });
            btn.classList.add('bg-success');
            btn.classList.add('text-white');
            btn.classList.remove('text-success');
            
            // Smooth scroll to form
            const formSection = document.getElementById('startTimeSelect');
            if (formSection) {
               window.scrollTo({ top: formSection.getBoundingClientRect().top + window.scrollY - 200, behavior: 'smooth' });
            }
          });
      }
    });
  });
</script>

<style>
  .slot-btn:hover:not(:disabled) {
    transform: scale(1.05);
    background-color: var(--primary-color) !important;
    color: #fff !important;
    box-shadow: 0 5px 15px rgba(var(--primary-rgb), 0.3);
  }
  .bg-success-bg { background-color: rgba(30, 215, 96, 0.1); }
  .bg-danger-bg { background-color: rgba(255, 69, 58, 0.1); }
</style>
