<section class="container py-5 mt-4">
  <div class="mb-5 pb-3 border-bottom d-flex flex-column flex-md-row justify-content-between align-items-md-center">
    <div>
      <div class="badge bg-danger-bg text-danger mb-2 px-3 py-2 shadow-sm rounded-pill fw-bold text-uppercase" style="letter-spacing: 0.05em;">
        <i class="fa-solid fa-shield-halved me-2"></i>Admin Dashboard
      </div>
      <h2 class="display-6 fw-bold mb-1 font-outfit text-dark">Platform Overview</h2>
      <p class="text-muted fs-6 mb-0">Monitor network activity, user registrations, and venue approvals.</p>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <!-- Stat Cards with Premium UX -->
    <div class="col-sm-6 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative hover-lift">
        <div class="bg-primary position-absolute top-0 start-0 h-100 rounded-start-4" style="width: 6px;"></div>
        <div class="card-body p-4 d-flex align-items-center">
          <div class="bg-primary-subtle rounded-circle d-flex justify-content-center align-items-center me-4" style="width: 60px; height: 60px;">
            <i class="fa-solid fa-users fs-3 text-primary"></i>
          </div>
          <div>
            <div class="text-muted small text-uppercase fw-bold mb-1 tracking-wide" style="letter-spacing: 0.05em;">Total Users</div>
            <div class="fs-2 fw-bold text-dark lh-1 font-outfit"><%= summary.usersCount %></div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="col-sm-6 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative hover-lift">
        <div class="bg-warning position-absolute top-0 start-0 h-100 rounded-start-4" style="width: 6px;"></div>
        <div class="card-body p-4 d-flex align-items-center">
          <div class="bg-warning-bg rounded-circle d-flex justify-content-center align-items-center me-4" style="width: 60px; height: 60px;">
            <i class="fa-solid fa-user-clock fs-3 text-warning"></i>
          </div>
          <div>
            <div class="text-muted small text-uppercase fw-bold mb-1 tracking-wide" style="letter-spacing: 0.05em;">Pending Owners</div>
            <div class="fs-2 fw-bold text-dark lh-1 font-outfit"><%= summary.ownersPending %></div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="col-sm-6 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative hover-lift">
        <div class="bg-danger position-absolute top-0 start-0 h-100 rounded-start-4" style="width: 6px;"></div>
        <div class="card-body p-4 d-flex align-items-center">
          <div class="bg-danger-bg rounded-circle d-flex justify-content-center align-items-center me-4" style="width: 60px; height: 60px;">
            <i class="fa-solid fa-building-circle-exclamation fs-3 text-danger"></i>
          </div>
          <div>
            <div class="text-muted small text-uppercase fw-bold mb-1 tracking-wide" style="letter-spacing: 0.05em;">Pending Venues</div>
            <div class="fs-2 fw-bold text-dark lh-1 font-outfit"><%= summary.venuesPending %></div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="col-sm-6 col-lg-3">
      <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative hover-lift">
        <div class="bg-success position-absolute top-0 start-0 h-100 rounded-start-4" style="width: 6px;"></div>
        <div class="card-body p-4 d-flex align-items-center">
          <div class="bg-success-bg rounded-circle d-flex justify-content-center align-items-center me-4" style="width: 60px; height: 60px;">
            <i class="fa-solid fa-calendar-check fs-3 text-success"></i>
          </div>
          <div>
            <div class="text-muted small text-uppercase fw-bold mb-1 tracking-wide" style="letter-spacing: 0.05em;">Total Bookings</div>
            <div class="fs-2 fw-bold text-dark lh-1 font-outfit"><%= summary.bookingsCount %></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-light bg-gradient position-relative overflow-hidden mb-4">
    <div class="position-absolute end-0 top-0 opacity-10" style="transform: translate(10%, -20%); pointer-events: none;">
      <i class="fa-solid fa-gamepad" style="font-size: 14rem;"></i>
    </div>
    <h3 class="fw-bold mb-4 font-outfit d-flex align-items-center position-relative z-1"><i class="fa-solid fa-bolt text-warning me-2"></i> Quick Actions</h3>
    <div class="row g-3 position-relative z-1">
      <div class="col-lg-4">
        <a class="btn btn-outline-primary h-100 w-100 d-flex flex-column align-items-start p-4 rounded-4 shadow-sm bg-white" href="/admin/users">
          <i class="fa-solid fa-user-check fs-3 mb-2 text-primary"></i>
          <span class="fs-5 fw-bold text-dark font-outfit">Review Owners</span>
          <span class="text-muted small fw-normal mt-1 text-start">Approve or reject new venue owners</span>
        </a>
      </div>
      <div class="col-lg-4">
         <a class="btn btn-primary h-100 w-100 d-flex flex-column align-items-start p-4 rounded-4 shadow-sm" href="/admin/venues">
          <i class="fa-solid fa-building-circle-check fs-3 mb-2 text-white"></i>
          <span class="fs-5 fw-bold text-white font-outfit">Review Venues</span>
          <span class="text-white-50 small fw-normal mt-1 text-start">Approve new venues to be listed</span>
        </a>
      </div>
      <div class="col-lg-4">
        <a class="btn btn-outline-secondary h-100 w-100 d-flex flex-column align-items-start p-4 rounded-4 shadow-sm bg-white" href="/admin/payments">
          <i class="fa-solid fa-money-check-dollar fs-3 mb-2 text-secondary"></i>
          <span class="fs-5 fw-bold text-dark font-outfit">Payments & Disputes</span>
          <span class="text-muted small fw-normal mt-1 text-start">Manage platform earnings and disputes</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hover-lift {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .hover-lift:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
  }
</style>