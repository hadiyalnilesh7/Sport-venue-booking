<section class="container py-5 mt-4">
  <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center mb-5 pb-3 border-bottom">
    <div class="mb-4 mb-lg-0">
      <div class="badge bg-primary-subtle text-primary mb-2 px-3 py-2 shadow-sm rounded-pill fw-bold text-uppercase" style="letter-spacing: 0.05em;">
        <i class="fa-solid fa-building-user me-2"></i>Venue Owner Dashboard
      </div>
      <h2 class="display-6 fw-bold mb-1 font-outfit text-dark">Operations Overview</h2>
      <p class="text-muted fs-6 mb-0">Manage your sports venues, check recent bookings, and monitor revenue.</p>
    </div>
    <div class="d-flex flex-nowrap gap-2">
      <a class="btn btn-outline-primary fw-bold rounded-pill px-3 shadow-sm text-nowrap" href="/owner/venues"><i class="fa-solid fa-list-check me-2"></i>My Venues</a>
      <a class="btn btn-outline-primary fw-bold rounded-pill px-3 shadow-sm text-nowrap" href="/owner/offers"><i class="fa-solid fa-tags me-2"></i>Offers</a>
      <a class="btn btn-outline-primary fw-bold rounded-pill px-3 shadow-sm text-nowrap" href="/owner/payment-settings"><i class="fa-solid fa-gear me-2"></i>Payments</a>
      <a class="btn btn-primary fw-bold rounded-pill px-3 shadow-sm text-nowrap" href="/owner/venues/new"><i class="fa-solid fa-plus me-2"></i>Add Venue</a>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <!-- Stat Cards with Premium Shadow and Gradients -->
    <div class="col-sm-6 col-md-4 col-xl-2">
      <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative hover-lift">
        <div class="bg-primary position-absolute top-0 start-0 h-100 rounded-start-4" style="width: 6px;"></div>
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="text-muted small text-uppercase fw-bold" style="letter-spacing: 0.05em;">Venues</div>
            <div class="bg-primary-subtle text-primary rounded-circle d-flex justify-content-center align-items-center" style="width: 40px; height: 40px;"><i class="fa-solid fa-map-location-dot"></i></div>
          </div>
          <div class="fs-2 fw-bold text-dark font-outfit"><%= summary.totalVenues %></div>
        </div>
      </div>
    </div>
    <div class="col-sm-6 col-md-4 col-xl-2">
      <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative hover-lift">
        <div class="bg-info position-absolute top-0 start-0 h-100 rounded-start-4" style="width: 6px;"></div>
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="text-muted small text-uppercase fw-bold" style="letter-spacing: 0.05em;">Bookings</div>
            <div class="bg-info-bg text-info rounded-circle d-flex justify-content-center align-items-center" style="width: 40px; height: 40px;"><i class="fa-solid fa-calendar-check text-info"></i></div>
          </div>
          <div class="fs-2 fw-bold text-dark font-outfit"><%= summary.totalBookings %></div>
        </div>
      </div>
    </div>
    <div class="col-sm-6 col-md-4 col-xl-2">
      <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative hover-lift">
        <div class="bg-success position-absolute top-0 start-0 h-100 rounded-start-4" style="width: 6px;"></div>
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="text-muted small text-uppercase fw-bold" style="letter-spacing: 0.05em;">Today</div>
            <div class="bg-success-bg text-success rounded-circle d-flex justify-content-center align-items-center" style="width: 40px; height: 40px;"><i class="fa-solid fa-bolt text-success"></i></div>
          </div>
          <div class="fs-2 fw-bold text-dark font-outfit"><%= summary.todayBookings %></div>
        </div>
      </div>
    </div>
    <div class="col-sm-6 col-md-4 col-xl-2">
      <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative hover-lift">
        <div class="bg-warning position-absolute top-0 start-0 h-100 rounded-start-4" style="width: 6px;"></div>
        <div class="card-body p-4">
           <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="text-muted small text-uppercase fw-bold" style="letter-spacing: 0.05em;">Earned</div>
             <div class="bg-warning-bg text-warning rounded-circle d-flex justify-content-center align-items-center" style="width: 40px; height: 40px;"><i class="fa-solid fa-coins text-warning"></i></div>
           </div>
          <div class="fs-2 fw-bold text-dark font-outfit">₹<%= summary.monthlyEarnings %></div>
        </div>
      </div>
    </div>
    <div class="col-sm-6 col-md-4 col-xl-2">
      <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative hover-lift">
        <div class="bg-danger position-absolute top-0 start-0 h-100 rounded-start-4" style="width: 6px;"></div>
        <div class="card-body p-4">
           <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="text-muted small text-uppercase fw-bold" style="letter-spacing: 0.05em;">Offers</div>
            <div class="bg-danger-bg text-danger rounded-circle d-flex justify-content-center align-items-center" style="width: 40px; height: 40px;"><i class="fa-solid fa-ticket text-danger"></i></div>
           </div>
          <div class="fs-2 fw-bold text-dark font-outfit"><%= summary.activeOffers %></div>
        </div>
      </div>
    </div>
    <div class="col-sm-6 col-md-4 col-xl-2">
      <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative hover-lift">
        <div class="bg-secondary position-absolute top-0 start-0 h-100 rounded-start-4" style="width: 6px;"></div>
        <div class="card-body p-4">
           <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="text-muted small text-uppercase fw-bold" style="letter-spacing: 0.05em;">Slots</div>
             <div class="bg-light text-secondary border rounded-circle d-flex justify-content-center align-items-center" style="width: 40px; height: 40px;"><i class="fa-solid fa-chart-pie"></i></div>
           </div>
          <div class="fs-2 fw-bold text-dark font-outfit"><%= summary.slotUtilization %>%</div>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
    <h3 class="fw-bold mb-0 font-outfit text-dark"><i class="fa-solid fa-clock-rotate-left text-primary me-2"></i>Recent Tracking Bookings</h3>
    <a class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-bold shadow-sm" href="/owner/bookings">View All <i class="fa-solid fa-angle-right ms-1"></i></a>
  </div>

  <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th class="ps-4 py-3 text-muted text-uppercase small fw-bold" style="letter-spacing: 0.05em;">Booking ID</th>
            <th class="py-3 text-muted text-uppercase small fw-bold" style="letter-spacing: 0.05em;">Venue</th>
            <th class="py-3 text-muted text-uppercase small fw-bold" style="letter-spacing: 0.05em;">Date</th>
            <th class="py-3 text-muted text-uppercase small fw-bold" style="letter-spacing: 0.05em;">Status</th>
            <th class="pe-4 py-3 text-muted text-uppercase small fw-bold" style="letter-spacing: 0.05em;">Advance Paid</th>
          </tr>
        </thead>
        <tbody>
          <% if (!bookings || bookings.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center py-5">
                <i class="fa-regular fa-folder-open text-muted opacity-50 mb-3" style="font-size: 3rem;"></i>
                <h5 class="fw-bold text-dark">No recent bookings</h5>
                <p class="text-muted mb-0">Bookings placed by users will appear here.</p>
              </td>
            </tr>
          <% } %>
          <% bookings.forEach((booking) => { %>
            <tr class="transition-fast hover-bg">
              <td class="ps-4 py-4 fw-bold text-primary font-outfit"><i class="fa-solid fa-hashtag text-muted me-1"></i><%= booking.bookingCode %></td>
              <td class="py-4 text-dark fw-bold"><%= booking.venue.name %></td>
              <td class="py-4 text-muted fw-medium"><i class="fa-solid fa-calendar-day text-secondary me-2"></i><%= formatDate(booking.bookingDate) %></td>
              <td class="py-4">
                <span class="badge rounded-pill px-3 py-2 fw-bold text-uppercase <%= booking.bookingStatus === 'Confirmed' ? 'bg-success-bg text-success' : (booking.bookingStatus === 'Pending' ? 'bg-warning-bg text-warning' : (booking.bookingStatus === 'Payment Due' ? 'bg-danger-subtle text-danger border border-danger border-opacity-25' : 'bg-light text-muted border')) %>" style="letter-spacing: 0.05em;">
                  <%= booking.bookingStatus %>
                </span>
              </td>
              <td class="pe-4 py-4 fw-bold text-dark fs-5">₹<%= booking.pricingBreakdown.bookingAmount %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .hover-bg:hover {
    background-color: var(--bg-surface-hover) !important;
  }
  .hover-lift {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .hover-lift:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
  }
</style>