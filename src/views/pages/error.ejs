<section class="container d-flex align-items-center justify-content-center min-vh-100 py-5">
  <div class="text-center max-w-500 mx-auto">
    <div class="mb-4">
       <span class="display-1 fw-bold text-primary opacity-25 font-outfit"><%= error.statusCode || 500 %></span>
    </div>
    
    <div class="card border-0 shadow-lg rounded-4 p-5 bg-white mb-5 transition-fast hover-lift">
      <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4" style="width: 80px; height: 80px;">
        <i class="fa-solid fa-triangle-exclamation fs-2"></i>
      </div>
      
      <div class="badge bg-danger-bg text-danger mb-3 px-3 py-1 rounded-pill fw-bold text-uppercase small">System Message</div>
      <h2 class="fw-bold text-dark font-outfit mb-3">Something went wrong</h2>
      <p class="text-muted fs-6 mb-4"><%= error.message || 'The server encountered an unexpected error.' %></p>
      
      <div class="d-grid gap-2">
        <a href="/" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm py-3">
          <i class="fa-solid fa-house me-2"></i>Return Home
        </a>
        <button onclick="window.history.back()" class="btn btn-link text-muted fw-bold text-decoration-none small">
          <i class="fa-solid fa-arrow-left me-1"></i> Go Back
        </button>
      </div>
    </div>
    
    <p class="text-muted small opacity-75">If this persists, please contact our support team with code #ERR-<%= error.statusCode || '500' %></p>
  </div>
</section>

<style>
  .max-w-500 { max-width: 500px; }
  .bg-danger-bg { background-color: rgba(255, 69, 58, 0.1); }
</style>