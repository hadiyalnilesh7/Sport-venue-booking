<% const heroImage = venue.photos && venue.photos[0] ? venue.photos[0] : 'https://images.unsplash.com/photo-1517649763962-0c623066013b?auto=format&fit=crop&w=1200&q=80'; %>

<div class="position-relative bg-dark" style="height: 400px; overflow: hidden;">
  <div style="position: absolute; inset: 0; background-image: url('<%= heroImage %>'); background-size: cover; background-position: center; opacity: 0.6; mix-blend-mode: overlay;"></div>
  <div style="position: absolute; inset: 0; background: linear-gradient(to top, var(--bg-body) 0%, transparent 100%);"></div>
  <div class="container h-100 position-relative z-1 d-flex flex-column justify-content-end pb-5">
    <div class="d-flex justify-content-between align-items-end mb-3">
      <div>
        <span class="badge bg-primary px-3 py-2 rounded-pill fw-bold text-uppercase tracking-wide mb-3"><i class="fa-solid fa-medal me-2"></i>Premium Venue</span>
        <h1 class="display-4 fw-bold text-white mb-2 font-outfit" style="text-shadow: 0 2px 10px rgba(0,0,0,0.3);"><%= venue.name %></h1>
        <p class="text-white fw-medium fs-5 m-0 d-flex align-items-center" style="text-shadow: 0 1px 5px rgba(0,0,0,0.5);">
          <i class="fa-solid fa-location-dot text-warning me-2"></i><%= venue.location.address %>, <%= venue.location.city %>
        </p>
      </div>
      <div class="d-none d-md-flex flex-column align-items-end">
        <div class="bg-white text-dark px-4 py-3 rounded-4 shadow-lg text-center d-flex flex-column align-items-center mb-2">
          <div class="fs-2 fw-bold font-outfit text-primary lh-1"><i class="fa-solid fa-star text-warning me-1"></i><%= venue.ratingAverage ? venue.ratingAverage.toFixed(1) : 'New' %></div>
          <span class="text-muted small fw-semibold mt-1"><%= reviews.length %> Reviews</span>
        </div>
      </div>
    </div>
  </div>
</div>

<section class="container py-4" style="margin-top: -2rem; position: relative; z-index: 5;">
  <div class="row g-4 position-relative">
    <div class="col-lg-8">
      <div class="card p-4 p-md-5 border-0 shadow-sm mb-4">
        <h3 class="fw-bold mb-4 font-outfit d-flex align-items-center border-bottom pb-3"><i class="fa-solid fa-circle-info text-primary me-2"></i> About the Venue</h3>
        <p class="text-muted fs-6 lh-lg mb-0"><%= venue.description %></p>
      </div>

      <div class="card p-4 p-md-5 border-0 shadow-sm mb-4">
        <h3 class="fw-bold mb-4 font-outfit d-flex align-items-center border-bottom pb-3"><i class="fa-solid fa-bolt text-warning me-2"></i> Features & Pricing Overview</h3>
        <div class="row g-4">
          <div class="col-md-6">
            <div class="d-flex align-items-start p-4 bg-primary-subtle rounded-4 h-100 transition-normal hover-lift">
              <div class="bg-white rounded-circle p-3 shadow-sm me-3 text-primary d-flex align-items-center justify-content-center">
                <i class="fa-solid fa-basketball fs-3"></i>
              </div>
              <div>
                <span class="text-uppercase text-primary fw-bold mb-1 d-block" style="font-size: 0.75rem; letter-spacing: 0.05em;">Sports</span>
                <div class="fw-bold text-dark fs-5"><%= venue.sportTypes.join(', ') %></div>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="d-flex align-items-start p-4 bg-primary-subtle rounded-4 h-100 transition-normal hover-lift">
              <div class="bg-white rounded-circle p-3 shadow-sm me-3 text-primary d-flex align-items-center justify-content-center">
                <i class="fa-regular fa-clock fs-3"></i>
              </div>
              <div>
                <span class="text-uppercase text-primary fw-bold mb-1 d-block" style="font-size: 0.75rem; letter-spacing: 0.05em;">Operating Hours</span>
                <div class="fw-bold text-dark fs-5"><%= venue.openingTime %> - <%= venue.closingTime %></div>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="d-flex align-items-start p-4 bg-primary-subtle rounded-4 h-100 transition-normal hover-lift">
              <div class="bg-white rounded-circle p-3 shadow-sm me-3 text-primary d-flex align-items-center justify-content-center">
                <i class="fa-solid fa-gamepad fs-3"></i>
              </div>
              <div>
                <span class="text-uppercase text-primary fw-bold mb-1 d-block" style="font-size: 0.75rem; letter-spacing: 0.05em;">Selected Sport</span>
                <div class="fw-bold text-dark fs-5"><%= selectedSportType || 'Not selected' %></div>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="d-flex align-items-start p-4 bg-primary-subtle rounded-4 h-100 transition-normal hover-lift">
              <div class="bg-white rounded-circle p-3 shadow-sm me-3 text-primary d-flex align-items-center justify-content-center">
                <i class="fa-solid fa-wallet fs-3"></i>
              </div>
              <div>
                <span class="text-uppercase text-primary fw-bold mb-1 d-block" style="font-size: 0.75rem; letter-spacing: 0.05em;">Price for <%= selectedSportType || 'Sport' %></span>
                <div class="fw-bold text-dark fs-5">₹<%= pricingPreview.basePrice %> <span class="text-muted small fw-normal">/slot on selected date</span></div>
              </div>
            </div>
          </div>
          <div class="col-12">
            <div class="rounded-4 border bg-light overflow-hidden">
              <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom bg-white">
                <div>
                  <h5 class="fw-bold mb-1 font-outfit">Sport-wise Slot Pricing</h5>
                  <p class="text-muted small mb-0">Each game can have its own weekday and weekend rate.</p>
                </div>
                <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill">Per Slot</span>
              </div>
              <div class="table-responsive">
                <table class="table align-middle mb-0">
                  <thead>
                    <tr>
                      <th class="px-4 py-3 text-muted text-uppercase small fw-bold">Sport</th>
                      <th class="px-4 py-3 text-muted text-uppercase small fw-bold">Weekday</th>
                      <th class="px-4 py-3 text-muted text-uppercase small fw-bold">Saturday</th>
                      <th class="px-4 py-3 text-muted text-uppercase small fw-bold">Sunday</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% sportPricingDetails.forEach((pricing) => { %>
                      <tr class="<%= pricing.sportType === selectedSportType ? 'table-primary' : '' %>">
                        <td class="px-4 py-3 fw-bold text-dark"><%= pricing.sportType %></td>
                        <td class="px-4 py-3 text-dark">₹<%= pricing.weekdayPrice %></td>
                        <td class="px-4 py-3 text-dark">₹<%= pricing.saturdayPrice %></td>
                        <td class="px-4 py-3 text-dark">₹<%= pricing.sundayPrice %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <% if (activeOffers && activeOffers.length > 0) { %>
      <div class="card p-4 p-md-5 border-0 shadow-sm mb-4" style="background: linear-gradient(135deg, #fff8f0, #fff3f3);">
        <h3 class="fw-bold mb-4 font-outfit d-flex align-items-center border-bottom pb-3"><i class="fa-solid fa-tags text-danger me-2"></i> Active Offers</h3>
        <div class="row g-3">
          <% activeOffers.forEach((offer) => { %>
            <div class="col-md-6">
              <div class="card border-0 rounded-4 p-4 h-100 hover-lift" style="background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%); color: #fff;">
                <div class="d-flex justify-content-between align-items-start mb-3">
                  <span class="badge bg-white text-danger fw-bold px-3 py-2 rounded-pill" style="font-size: 0.8rem;">
                    <% if (offer.discountType === 'percentage') { %>
                      <i class="fa-solid fa-percent me-1"></i><%= offer.discountValue %>% OFF
                    <% } else { %>
                      <i class="fa-solid fa-indian-rupee-sign me-1"></i><%= offer.discountValue %> OFF
                    <% } %>
                  </span>
                  <span class="badge bg-white bg-opacity-25 text-white px-2 py-1 rounded-pill" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em;"><%= offer.appliesOn %></span>
                </div>
                <h5 class="fw-bold mb-2 font-outfit" style="color: #fff;"><%= offer.title %></h5>
                <% if (offer.code) { %>
                  <div class="d-flex align-items-center gap-2 mb-3">
                    <span class="small fw-semibold" style="opacity: 0.85;">Coupon Code:</span>
                    <span class="badge bg-white text-danger fw-bold px-3 py-1 rounded font-monospace" style="letter-spacing: 0.1em;"><%= offer.code %></span>
                  </div>
                <% } %>
                <div class="mt-auto d-flex align-items-center gap-1" style="opacity: 0.85; font-size: 0.8rem;">
                  <i class="fa-regular fa-calendar me-1"></i>
                  Valid: <%= formatDate(offer.startDate) %> &ndash; <%= formatDate(offer.endDate) %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <div class="card p-4 p-md-5 border-0 shadow-sm mb-4">
        <div class="row g-4">
          <% if (!reviews.length) { %>
            <div class="col-12">
              <div class="text-center py-5 bg-light rounded-4">
                <i class="fa-regular fa-comment-dots fs-1 text-muted mb-3"></i>
                <h5 class="fw-bold text-dark">No reviews yet</h5>
                <p class="text-muted mb-0">Be the first to leave a review after your booking.</p>
              </div>
            </div>
          <% } %>
          <% reviews.forEach((review) => { %>
            <div class="col-md-6">
              <div class="card h-100 border border-light bg-light rounded-4 p-4 hover-lift">
                <div class="d-flex justify-content-between align-items-center mb-3">
                  <div class="fw-bold text-dark d-flex align-items-center">
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2 fw-bold" style="width: 32px; height: 32px; font-size: 0.8rem;">
                      <%= review.user.fullName.charAt(0).toUpperCase() %>
                    </div>
                    <%= review.user.fullName %>
                  </div>
                  <span class="bg-white rounded-pill px-2 py-1 shadow-sm text-dark fw-bold" style="font-size: 0.8rem;"><i class="fa-solid fa-star text-warning me-1"></i><%= review.rating %></span>
                </div>
                <p class="text-muted mb-0 fs-6">"<%= review.comment %>"</p>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Right Sidebar (Booking panel) -->
    <div class="col-lg-4">
      <div class="position-sticky" style="top: 100px;">
        <div class="card shadow-lg border-0 p-4 p-md-4 rounded-4" style="background: linear-gradient(to bottom, #ffffff, #f8fafc);">
          <% const availableSlots = slots.filter((slot) => slot.isAvailable); %>
          <div class="d-flex align-items-center justify-content-between border-bottom pb-3 mb-4">
             <h4 class="fw-bold text-dark font-outfit m-0"><i class="fa-solid fa-calendar-check text-primary me-2"></i>Secure a Slot</h4>
             <% if(availableSlots.length > 0) { %>
               <span class="badge bg-success-bg text-success px-2 py-1 rounded-pill"><i class="fa-solid fa-check me-1"></i> Available</span>
             <% } else { %>
               <span class="badge bg-danger-bg text-danger px-2 py-1 rounded-pill"><i class="fa-solid fa-xmark me-1"></i> Sold Out</span>
             <% } %>
          </div>
          
          <form action="/venues/<%= venue.slug %>/book" method="POST" enctype="multipart/form-data">
            <div class="mb-3">
              <label class="form-label fw-bold text-muted small text-uppercase" style="letter-spacing: 0.05em;"><i class="fa-solid fa-basketball text-warning me-1"></i> Sport Type</label>
              <select name="sportType" class="form-select form-select-lg bg-white shadow-sm border-0" onchange="window.location='?date=' + encodeURIComponent(document.querySelector('[name=bookingDate]').value) + '&sportType=' + encodeURIComponent(this.value)">
                <% venue.sportTypes.forEach((sport) => { %>
                  <option value="<%= sport %>" <%= sport === selectedSportType ? 'selected' : '' %>><%= sport %></option>
                <% }) %>
              </select>
              <div class="form-text small opacity-75">Choose a sport to load its slot price for this date.</div>
            </div>

            <div class="mb-3">
              <label class="form-label fw-bold text-muted small text-uppercase" style="letter-spacing: 0.05em;"><i class="fa-regular fa-calendar text-primary me-1"></i> Booking Date</label>
              <input type="date" name="bookingDate" value="<%= selectedDate %>" onchange="window.location='?date=' + this.value + '&sportType=' + encodeURIComponent(document.querySelector('[name=sportType]').value)" class="form-control form-control-lg bg-white shadow-sm border-0" />
            </div>

            <div class="mb-4">
              <label class="form-label fw-bold text-muted small text-uppercase" style="letter-spacing: 0.05em;"><i class="fa-regular fa-clock text-success me-1"></i> Select Slot</label>
              <div class="position-relative">
                <select name="slotStartTime" class="form-select form-select-lg bg-white shadow-sm border-0" <%= availableSlots.length ? '' : 'disabled' %>>
                  <option value=""><%= availableSlots.length ? `Choose from ${availableSlots.length} available slot(s)` : 'No available slots' %></option>
                  <% availableSlots.forEach((slot) => { %>
                    <option value="<%= slot.startTime %>"><%= slot.startTime %> - <%= slot.endTime %></option>
                  <% }) %>
                </select>
              </div>
            </div>

            <div class="card bg-primary-subtle border-0 rounded-4 p-4 mb-4 position-relative overflow-hidden">
              <div class="position-absolute end-0 bottom-0 opacity-10" style="transform: translate(20%, 20%); pointer-events: none;">
                <i class="fa-solid fa-money-bill-wave" style="font-size: 6rem;"></i>
              </div>
              <h5 class="fw-bold text-primary mb-1 font-outfit position-relative z-1"><i class="fa-solid fa-shield-halved me-2"></i>Advance Payment</h5>
              <p class="small text-muted mb-4 position-relative z-1">Pay the advance to securely lock this <strong><%= selectedSportType %></strong> slot.</p>
              
              <% if (pricingPreview.discountAmount > 0) { %>
                <div class="d-flex justify-content-between align-items-center mb-2 bg-white px-3 py-2 rounded-3 shadow-sm position-relative z-1">
                  <span class="text-secondary fw-semibold small">Original Price</span>
                  <span class="text-muted text-decoration-line-through fw-semibold">₹<%= pricingPreview.basePrice %></span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-2 bg-white px-3 py-2 rounded-3 shadow-sm position-relative z-1">
                  <span class="text-success fw-semibold small d-flex align-items-center gap-1"><i class="fa-solid fa-tags"></i> <%= pricingPreview.appliedOfferLabel %></span>
                  <span class="text-success fw-bold">- ₹<%= pricingPreview.discountAmount %></span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-2 bg-white px-3 py-2 rounded-3 shadow-sm position-relative z-1">
                  <span class="text-secondary fw-semibold small">Discounted Price</span>
                  <strong class="text-dark fw-bold">₹<%= pricingPreview.totalPrice %></strong>
                </div>
              <% } %>
              <div class="d-flex justify-content-between align-items-center mb-3 bg-white p-3 rounded-3 shadow-sm position-relative z-1">
                <span class="text-secondary fw-semibold">Advance Required</span>
                <strong class="text-primary fs-4">₹<%= pricingPreview.bookingAmount %></strong>
              </div>

              <div class="d-flex justify-content-between align-items-center mb-4 position-relative z-1">
                <span class="text-secondary fw-semibold">UPI ID directly</span>
                <strong class="text-dark bg-white px-2 py-1 rounded shadow-sm border"><%= venue.owner && venue.owner.paymentDetails && venue.owner.paymentDetails.upiId ? venue.owner.paymentDetails.upiId : 'Not configured' %></strong>
              </div>

              <% if (venue.owner && venue.owner.paymentDetails && venue.owner.paymentDetails.qrCodeImage) { %>
                <div class="text-center mb-4 position-relative z-1">
                  <div class="d-inline-block bg-white p-2 rounded-4 shadow-sm">
                    <img src="<%= venue.owner.paymentDetails.qrCodeImage %>" alt="Owner QR code" class="img-fluid rounded" style="max-width: 130px;" />
                  </div>
                  <div class="mt-2 text-muted small fw-semibold">Scan to pay</div>
                </div>
              <% } %>

              <div class="mb-3 position-relative z-1">
                <label class="form-label small fw-bold text-muted mb-1 text-uppercase">Payment Reference ID</label>
                <input type="text" name="paymentReference" placeholder="e.g. UPI Ref / Trxn ID" required class="form-control bg-white shadow-sm border-0" />
              </div>

              <div class="mb-0 position-relative z-1">
                <label class="form-label small fw-bold text-muted mb-1 text-uppercase">Proof of Payment</label>
                <input type="file" name="paymentScreenshot" accept="image/*" required class="form-control bg-white shadow-sm border-0" />
              </div>
            </div>

            <div class="card bg-light border-0 rounded-4 p-4 mb-4">
              <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                <span class="text-muted fw-semibold">Total Price</span>
                <div class="text-end">
                  <% if (pricingPreview.discountAmount > 0) { %>
                    <div class="text-muted text-decoration-line-through small">₹<%= pricingPreview.basePrice %></div>
                  <% } %>
                  <strong class="text-dark fs-5">₹<%= pricingPreview.totalPrice %></strong>
                </div>
              </div>
              <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted fw-semibold">Due at Venue</span>
                <strong class="text-danger fs-5 bg-danger-bg px-2 py-1 rounded">₹<%= pricingPreview.remainingAmount %></strong>
              </div>
            </div>

            <div class="d-grid mt-2">
              <% if (currentUser && currentUser.role === 'user') { %>
                <button class="btn btn-primary btn-lg rounded-pill fw-bold shadow position-relative overflow-hidden" type="submit" <%= availableSlots.length ? '' : 'disabled' %>>
                  <span class="position-relative z-1 d-flex align-items-center justify-content-center">
                    <i class="fa-solid fa-circle-check me-2"></i> Confirm & Book Slot
                  </span>
                </button>
              <% } else { %>
                <a class="btn btn-outline-primary btn-lg rounded-pill fw-bold" href="/auth/login"><i class="fa-regular fa-user me-2"></i> Login to Book</a>
              <% } %>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="container py-5 mt-4">
  <div class="card p-4 p-md-5 border-0 shadow-sm rounded-4 text-center mb-4 bg-white">
    <h3 class="fw-bold font-outfit mb-3"><i class="fa-regular fa-calendar-days text-primary me-2"></i> Full Schedule for <span class="text-primary"><%= formatDate(selectedDate) %></span></h3>
    <p class="text-muted mb-0">Check all slot availabilities below and pick your preferred time.</p>
  </div>
  
  <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4">
    <% slots.forEach((slot) => { %>
      <div class="col">
        <div class="card h-100 border-0 p-4 rounded-4 shadow-sm text-center <%= slot.isAvailable ? 'bg-success-bg text-dark border-start border-success border-4' : 'bg-light text-muted opacity-75' %> transition-normal hover-lift">
          <div class="d-flex flex-column align-items-center justify-content-center h-100 gap-2">
            <i class="fa-regular <%= slot.isAvailable ? 'fa-clock text-success' : 'fa-circle-xmark text-muted' %> fs-3 mb-1"></i>
            <div class="fw-bold fs-5 tracking-wide"><%= slot.startTime %></div>
            <div class="text-muted small mb-2"><%= slot.endTime %></div>
            <div class="badge <%= slot.isAvailable ? 'bg-success text-white px-3 py-2' : 'bg-secondary text-white' %> rounded-pill d-inline-flex align-items-center">
              <%= slot.isAvailable ? 'Available' : 'Booked' %>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<style>
  .hover-lift {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .hover-lift:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
  }
</style>